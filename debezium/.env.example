# =============================================
# Debezium — Environment Variables (EXAMPLE)
# =============================================

# Apache Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# SQL Server (source)
SQLSERVER_HOST=<your-sqlserver-host>
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=<your-database>
SQLSERVER_USER=<your-user>
SQLSERVER_PASSWORD=<your-password>

# PostgreSQL (target)
POSTGRES_HOST=<your-postgres-host>
POSTGRES_PORT=5432
POSTGRES_DATABASE=<your-database>
POSTGRES_USER=<your-user>
POSTGRES_PASSWORD=<your-password>

# Topic & schema naming
TOPIC_PREFIX=source
TARGET_SCHEMA=bronze

# Regex applied to source tables (only tables matching this pattern
# are consumed by the Sink). Defaults match common Brazilian naming
# conventions: tbCamelCase, TBPASCALCASE, VADU*.
TABLE_REGEX_PATTERN=tb[A-Z]|TB|VADU
