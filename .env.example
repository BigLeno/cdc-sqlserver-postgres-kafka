# =============================================
# CDC Pipeline — Environment Variables (EXAMPLE)
# =============================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to version control.
# =============================================

# Apache Kafka (KRaft)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# SQL Server — Source
SQLSERVER_HOST=<your-sqlserver-host>
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=<your-database>
SQLSERVER_USERNAME=<your-user>
SQLSERVER_PASSWORD=<your-password>

# PostgreSQL — Target
POSTGRES_HOST=<your-postgres-host>
POSTGRES_PORT=5432
POSTGRES_DATABASE=<your-database>
POSTGRES_SCHEMA=bronze
POSTGRES_USERNAME=<your-user>
POSTGRES_PASSWORD=<your-password>

# Debezium
DEBEZIUM_CONNECT_PORT=8083

# Kafka UI
KAFKA_UI_PORT=8080
KAFKA_UI_USERNAME=<your-ui-user>
KAFKA_UI_PASSWORD=<your-ui-password>

# Nginx
NGINX_HOST=<your-public-host-or-ip>
